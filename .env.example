# Copy this to .env and fill in values. Never commit .env.

# Google Gemini (free tier — aistudio.google.com)
GOOGLE_API_KEY=AIza...

# LangSmith — get key at smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=migrainetackler

# Weather (free tier — openweathermap.org)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Austin
OPENWEATHER_COUNTRY_CODE=US

# AQI (free tier — airnowapi.org, US only)
AIRNOW_API_KEY=
AIRNOW_ZIP=78701

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/migrainetackler  # pragma: allowlist secret

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_DAYS=30

# App
LOG_LEVEL=INFO
