# Copy this to .env and fill in values. Never commit .env.

# Google Gemini (free tier — aistudio.google.com)
GOOGLE_API_KEY=AIza...

# LangSmith — get key at smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=migrainetackler

# Weather (free tier — openweathermap.org)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Austin
OPENWEATHER_COUNTRY_CODE=US

# AQI (free tier — airnowapi.org, US only)
AIRNOW_API_KEY=
AIRNOW_ZIP=78701

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/migrainetackler  # pragma: allowlist secret

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_DAYS=30

# Apple Shortcuts — generate with: python -c "import secrets; print(secrets.token_hex(24))"
SHORTCUTS_API_KEY=

# Gmail SMTP alerts (red flag + MOH notifications)
# Use an App Password, NOT your main Gmail password
# Enable at: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_USER=your@gmail.com
SMTP_PASSWORD=                    # pragma: allowlist secret
ALERT_EMAIL=your@gmail.com        # can be the same as SMTP_USER

# App
LOG_LEVEL=INFO
